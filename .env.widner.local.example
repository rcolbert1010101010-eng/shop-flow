# Frontend Supabase client
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend Supabase admin client
# Keep SUPABASE_URL aligned with VITE_SUPABASE_URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Backend admin API key (for x-shopflow-admin-key header)
X_SHOPFLOW_ADMIN_KEY=your_shopflow_admin_key_here
# Backend service key for qb-sender proxy endpoint
SHOPFLOW_SERVICE_KEY=your_shopflow_service_key_here

# Widner owner bootstrap inputs
WIDNER_OWNER_EMAIL=owner@example.com
WIDNER_OWNER_PASSWORD=replace_with_strong_password
WIDNER_OWNER_FULL_NAME=Widner Owner
WIDNER_TENANT_NAME=Widner
